{
  "name": "@alligo/eliza-plugin",
  "version": "1.0.0",
  "description": "AlliGo risk scoring plugin for Eliza agents - check agent trust scores before transactions",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "bun test",
    "lint": "eslint src/"
  },
  "keywords": [
    "eliza",
    "ai-agent",
    "risk-scoring",
    "trust",
    "alligo",
    "credit-bureau"
  ],
  "author": "AlliGo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/spiritclawd/AlliGo",
    "directory": "packages/eliza-plugin"
  },
  "bugs": {
    "url": "https://github.com/spiritclawd/AlliGo/issues"
  },
  "homepage": "https://alligo.io",
  "peerDependencies": {
    "@elizaos/core": ">=0.1.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  }
}
